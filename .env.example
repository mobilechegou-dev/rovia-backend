# ════════════════════════════════════════════════════════════════════════════════
# ROVIA API — Variáveis de Ambiente
# ════════════════════════════════════════════════════════════════════════════════
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais
# 3. NUNCA comite o .env no Git
# 4. Para produção, use um gerenciador de secrets (AWS Secrets Manager, Vault)
# ════════════════════════════════════════════════════════════════════════════════

# ─── APLICAÇÃO ────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
LOG_LEVEL=INFO

# ─── BANCO DE DADOS (PostgreSQL) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rovia_dev
DB_USER=rovia
DB_PASSWORD=rovia_secret
DB_POOL_MAX=10
DB_POOL_MIN=3

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── JWT ─────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO: Gere com: openssl rand -base64 32
# Deve ser uma string Base64 de no mínimo 256 bits (32 bytes)
JWT_SECRET=GERE_COM_openssl_rand_-base64_32
JWT_ACCESS_EXPIRATION=3600        # 1 hora em segundos
JWT_REFRESH_EXPIRATION=2592000    # 30 dias em segundos

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN_1=http://localhost:3000
CORS_ORIGIN_2=http://localhost:8081

# ─── pgAdmin (ferramentas de dev, não necessário em produção) ─────────────────
PGADMIN_EMAIL=admin@rovia.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
REDIS_UI_PORT=8081

# ─── FIREBASE (notificações push) ─────────────────────────────────────────────
# Fase 5 — preencher quando integrar notificações
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# ─── STORAGE (AWS S3 ou Cloudflare R2 — fotos de carga e perfil) ──────────────
# Fase 2 — preencher quando integrar upload
STORAGE_BUCKET_NAME=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=

# ─── GOOGLE MAPS ──────────────────────────────────────────────────────────────
# Fase 3 — preencher quando integrar mapas
GOOGLE_MAPS_API_KEY=
